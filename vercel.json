{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/ig",
      "destination": "/links?utm_source=ig_bio&utm_medium=linkinbio",
      "permanent": false
    },
    {
      "source": "/tiktok",
      "destination": "/links?utm_source=tiktok_bio&utm_medium=linkinbio",
      "permanent": false
    },
    {
      "source": "/yt",
      "destination": "/links?utm_source=yt_desc&utm_medium=linkinbio",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "(?<subdomain>store)\\..*"
        }
      ],
      "destination": "/nogear.html"
    },
    {
      "source": "/nogear",
      "destination": "/nogear.html"
    },
    {
      "source": "/womens",
      "destination": "/womens-only-flyer"
    },
    {
      "source": "/teens-adults",
      "destination": "/teens-adults-flyer"
    },
    {
      "source": "/kids",
      "destination": "/kids-boxing-flyer"
    }
  ]
}